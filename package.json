{
    "name": "coverit-api",
    "private": true,
    "version": "0.1.0",
    "description": "CoverIt REST API — Node.js + TypeScript backend",
    "type": "commonjs",
    "scripts": {
        "dev": "nodemon",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint .",
        "commit": "cz",
        "prepare": "husky",
        "docker": "sh docker.sh"
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "helmet": "^7.1.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@commitlint/cz-commitlint": "^20.4.3",
        "@eslint/js": "^9.21.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^22.0.0",
        "commitizen": "^4.3.1",
        "eslint": "^9.21.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "nodemon": "^3.1.4",
        "ts-node": "^10.9.2",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.24.1",
        "@coveritlabs/git-hooks": "github:CoveritLabs/.github"
    }
}