{
    "name": "coverit-api",
    "private": true,
    "version": "0.1.0",
    "description": "CoverIt REST API — Node.js + TypeScript backend",
    "type": "commonjs",
    "scripts": {
        "dev": "nodemon",
        "build": "prisma generate && tsc && tsc-alias",
        "start": "node dist/index.js",
        "postinstall": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "test": "jest --forceExit --detectOpenHandles",
        "test:coverage": "jest --forceExit --detectOpenHandles --coverage",
        "lint": "eslint .",
        "commit": "cz",
        "prepare": "husky",
        "docker": "sh docker.sh"
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.4.3",
        "@bufbuild/protobuf": "^2.11.0",
        "@coveritlabs/contracts": "^1.1.0",
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "argon2": "^0.44.0",
        "bullmq": "^5.71.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "helmet": "^7.1.0",
        "http-status-codes": "^2.3.0",
        "ioredis": "^5.10.0",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.20.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "prisma": "^7.4.2",
        "resend": "^6.9.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@commitlint/cz-commitlint": "^20.4.3",
        "@coveritlabs/git-hooks": "github:CoveritLabs/.github",
        "@eslint/js": "^9.21.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.18.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "commitizen": "^4.3.1",
        "eslint": "^9.21.0",
        "globals": "^15.15.0",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "nodemon": "^3.1.4",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.24.1"
    },
    "overrides": {
        "ioredis": "^5.10.0"
    }
}
